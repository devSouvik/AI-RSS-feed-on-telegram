# Environment Variables for RSS Feed Telegram Bot

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
# Your Azure OpenAI resource endpoint (e.g. https://<your-resource>.openai.azure.com)
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API Key (from Azure Portal → your OpenAI resource → Keys and Endpoint)
AZURE_OPENAI_API_KEY=

# Deployment name of your GPT-4o model (set in Azure AI Studio)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-nano

# Azure OpenAI API Version (keep this unless you have a specific version requirement)
AZURE_OPENAI_API_VERSION=2025-08-07


# ─── Application ──────────────────────────────────────────────────────────────
# Application environment: development | production
NODE_ENV=development

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# Max messages a single user can send per minute before being rate-limited
RATE_LIMIT_PER_USER_PER_MIN=5

# ─── Proxy (optional) ─────────────────────────────────────────────────────────
# If your network blocks Telegram (ECONNRESET errors), route via a proxy.
# Supports SOCKS5, SOCKS4, HTTP/HTTPS proxies.
# Examples:
#   TELEGRAM_PROXY=socks5://127.0.0.1:1080
#   TELEGRAM_PROXY=http://proxy.example.com:3128
# Leave blank or omit to connect directly.
# TELEGRAM_PROXY=
    